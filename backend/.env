# All of these are OPTIONAL. The app runs fully without any of them —
# weather lookups, the 5-day forecast, CRUD, and exports all work with zero keys.
#
# Set ONE of the keys below to also enable the AI-generated weather summary
# (Anthropic is used if both are present). Leave both blank to skip it.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: override the default model used for the AI summary
# AI_INSIGHT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# AI_INSIGHT_OPENAI_MODEL=gpt-4o-mini
